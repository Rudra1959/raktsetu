# ===========================
# RaktSetu Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ===========================

# ── Firebase ──
FIREBASE_PROJECT_ID=raktsetu-prod
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=raktsetu-prod.firebaseapp.com
FIREBASE_STORAGE_BUCKET=raktsetu-prod.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ── Google Maps Platform ──
GOOGLE_MAPS_API_KEY_ANDROID=your_android_maps_key
GOOGLE_MAPS_API_KEY_IOS=your_ios_maps_key
GOOGLE_MAPS_API_KEY_WEB=your_web_maps_key

# ── Google Cloud ──
GCP_PROJECT_ID=raktsetu-prod
GCP_REGION=asia-south1

# ── Vertex AI / Gemini ──
VERTEX_AI_LOCATION=asia-south1
GEMINI_MODEL=gemini-2.0-flash-exp

# ── Twilio (SMS Fallback) ──
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+91xxxxxxxxxx

# ── DigiLocker (Aadhaar KYC) ──
DIGILOCKER_CLIENT_ID=your_digilocker_client_id
DIGILOCKER_CLIENT_SECRET=your_digilocker_secret

# ── App Configuration ──
DEFAULT_SEARCH_RADIUS_KM=5
MAX_SEARCH_RADIUS_KM=100
DONATION_COOLDOWN_DAYS=56
ESCALATION_TIMEOUT_MINUTES=30
MAX_CANDIDATE_DONORS=5
